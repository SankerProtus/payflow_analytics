{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd PFA && npm ci"
  },
  "deploy": {
    "startCommand": "cd PFA && npm run migrate && npm run setup-stripe && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
